generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  PENDING // Default before they select Bride/Groom in setup
  BRIDE
  GROOM
  FAMILY
  OTHER
}

enum Visibility {
  BRIDE_PRIVATE
  GROOM_PRIVATE
  SHARED
}

enum ArrangementType {
  SEATING
  ROOMS
}

enum TableShape {
  CIRCULAR
  RECTANGULAR
}

enum VendorCategory {
  VENUE
  PHOTOGRAPHER
  MAKEUP_ARTIST
  CATERER
  DECORATOR
  PLANNER
  MEHNDI_ARTIST
}

enum PricingUnit {
  PER_DAY
  PER_EVENT
  PER_PLATE
  PACKAGE
}

enum VenueType {
  BANQUET
  HOTEL
  LAWN
  RESORT
}

enum PolicyType {
  IN_HOUSE
  EXTERNAL_ALLOWED
  NOT_ALLOWED
}

enum PricingModel {
  FIXED
  PERCENTAGE
}

model WeddingMember {
  id        String @id @default(uuid())
  userId    String
  weddingId String
  role      Role   @default(PENDING)

  side Role?

  privateTargetBudget Float?
  privateTargetDate   DateTime?

  canEditCombinedView Boolean @default(false)
  canEditGuests       Boolean @default(false)
  canManageBudget     Boolean @default(false)
  canManageEvents     Boolean @default(false)

  canViewPrivate Boolean @default(false)
  canEditPrivate Boolean @default(false) // Add/Edit only, no delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@unique([userId, weddingId])
  @@index([userId])
  @@index([weddingId])
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  weddingMembers WeddingMember[]
  activityLogs   ActivityLog[]

  createdEvents       Event[]             @relation("EventCreatedBy")
  createdInvitations  Invitation[]        @relation("InvitationCreatedBy")
  updatedInvitations  Invitation[]        @relation("InvitationUpdatedBy")
  createdGuests       Guest[]             @relation("GuestCreatedBy")
  updatedGuests       Guest[]             @relation("GuestUpdatedBy")
  createdBudgetItems  BudgetItem[]        @relation("BudgetCreatedBy")
  updatedBudgetItems  BudgetItem[]        @relation("BudgetUpdatedBy")
  createdTasks        ChecklistTask[]     @relation("TaskCreatedBy")
  updatedTasks        ChecklistTask[]     @relation("TaskUpdatedBy")
  createdInspirations PinnedInspiration[] @relation("InspirationCreatedBy")
  updatedInspirations PinnedInspiration[] @relation("InspirationUpdatedBy")
  createdArrangements Arrangement[]       @relation("ArrangementCreatedBy")
  updatedArrangements Arrangement[]       @relation("ArrangementUpdatedBy")
  vendorReviews       VendorReview[]
  shortlistedVendors  ShortlistedVendor[] @relation("ShortlistCreatedBy")
}

model Wedding {
  id                  String    @id @default(uuid())
  date                DateTime?
  location            String?
  budget              Int       @default(0)
  guestCount          Int       @default(0)
  weddingType         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime? @updatedAt
  setupCompleted      Boolean   @default(false)
  suggestedVenueName  String?
  suggestedVendorNote String?

  members            WeddingMember[]
  events             Event[]
  guests             Guest[]
  budgetItems        BudgetItem[]
  invitations        Invitation[]
  checklistTasks     ChecklistTask[]
  activityLogs       ActivityLog[]
  pinnedInspirations PinnedInspiration[]
  arrangements       Arrangement[]
  shortlistedVendors ShortlistedVendor[]
}

model Guest {
  id          String     @id @default(uuid())
  weddingId   String
  eventId     String?
  createdById String
  updatedById String?
  visibility  Visibility @default(SHARED)

  name      String
  email     String?
  rsvp      String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wedding         Wedding          @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  event           Event?           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy       User             @relation("GuestCreatedBy", fields: [createdById], references: [id])
  updatedBy       User?            @relation("GuestUpdatedBy", fields: [updatedById], references: [id])
  invites         GuestInvite[]
  seatAssignments SeatAssignment[]
  roomAssignments RoomAssignment[]

  @@unique([email, eventId])
  @@index([weddingId])
  @@index([eventId])
  @@index([createdById])
  @@index([updatedById])
}

model BudgetItem {
  id          String     @id @default(uuid())
  weddingId   String
  eventId     String?
  createdById String
  updatedById String?
  visibility  Visibility @default(SHARED)

  category  String
  estimated Int
  actual    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wedding   Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  event     Event?  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy User    @relation("BudgetCreatedBy", fields: [createdById], references: [id])
  updatedBy User?   @relation("BudgetUpdatedBy", fields: [updatedById], references: [id])

  @@index([weddingId])
  @@index([createdById])
  @@index([updatedById])
}

model Invitation {
  id          String     @id @default(uuid())
  weddingId   String
  eventId     String?
  createdById String
  updatedById String?
  visibility  Visibility @default(SHARED)

  message String
  token   String @unique

  templateId String

  title    String?
  names    String?
  date     String?
  time     String?
  venue    String?
  rsvpDate String?

  globalFontFamily String?
  styles           Json?

  isCustom         Boolean @default(false)
  canvasData       Json?
  customBackground String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wedding      Wedding       @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  event        Event?        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy    User          @relation("InvitationCreatedBy", fields: [createdById], references: [id])
  updatedBy    User?         @relation("InvitationUpdatedBy", fields: [updatedById], references: [id])
  guestInvites GuestInvite[]

  @@unique([weddingId, eventId, visibility])
  @@index([weddingId])
  @@index([eventId])
  @@index([createdById])
  @@index([updatedById])
}

model ChecklistTask {
  id          String     @id @default(uuid())
  weddingId   String
  eventId     String?
  createdById String
  updatedById String?
  visibility  Visibility @default(SHARED)

  title     String
  category  String
  priority  String    @default("MEDIUM")
  dueDate   DateTime?
  completed Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  wedding   Wedding            @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  event     Event?             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy User               @relation("TaskCreatedBy", fields: [createdById], references: [id])
  updatedBy User?              @relation("TaskUpdatedBy", fields: [updatedById], references: [id])
  subtasks  ChecklistSubTask[]

  @@index([weddingId])
  @@index([createdById])
  @@index([updatedById])
}

model ChecklistSubTask {
  id        String  @id @default(uuid())
  taskId    String
  title     String
  completed Boolean @default(false)

  task ChecklistTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model GuestInvite {
  id           String    @id @default(uuid())
  guestId      String
  invitationId String
  token        String    @unique
  status       String    @default("CREATED")
  sentAt       DateTime?
  respondedAt  DateTime?

  guest      Guest      @relation(fields: [guestId], references: [id], onDelete: Cascade)
  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([guestId])
  @@index([invitationId])
}

model ActivityLog {
  id         String     @id @default(uuid())
  weddingId  String
  userId     String
  eventId    String? // FIXED: Required for Event Isolation
  visibility Visibility @default(SHARED) // FIXED: Required for View Isolation
  action     String
  entity     String
  details    String?
  createdAt  DateTime   @default(now())

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  event   Event?  @relation(fields: [eventId], references: [id]) // FIXED: Relation link

  @@index([weddingId])
  @@index([userId])
  @@index([eventId]) // FIXED: Index for performance
}

model Event {
  id          String     @id @default(uuid())
  weddingId   String
  createdById String
  visibility  Visibility @default(SHARED)

  name     String
  date     DateTime?
  location String?
  budget   Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wedding   Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  createdBy User    @relation("EventCreatedBy", fields: [createdById], references: [id])

  guests             Guest[]
  budgetItems        BudgetItem[]
  tasks              ChecklistTask[]
  invitations        Invitation[]
  activityLogs       ActivityLog[]
  pinnedInspirations PinnedInspiration[]
  arrangements       Arrangement[]
  shortlistedVendors ShortlistedVendor[]

  @@index([weddingId])
}

model PinnedInspiration {
  id          String     @id @default(uuid())
  weddingId   String
  eventId     String?
  createdById String
  updatedById String?
  visibility  Visibility @default(SHARED)

  imageUrl String
  title    String?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wedding   Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  event     Event?  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy User    @relation("InspirationCreatedBy", fields: [createdById], references: [id])
  updatedBy User?   @relation("InspirationUpdatedBy", fields: [updatedById], references: [id])

  @@index([weddingId])
  @@index([eventId])
  @@index([createdById])
  @@index([updatedById])
}

model Arrangement {
  id          String     @id @default(uuid())
  weddingId   String
  eventId     String?
  createdById String
  updatedById String?
  visibility  Visibility @default(SHARED)

  name        String
  type        ArrangementType
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wedding   Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  event     Event?  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy User    @relation("ArrangementCreatedBy", fields: [createdById], references: [id])
  updatedBy User?   @relation("ArrangementUpdatedBy", fields: [updatedById], references: [id])

  tables      SeatingTable[]
  rooms       HotelRoom[]
  localGuests ArrangementGuest[]

  @@index([weddingId])
  @@index([eventId])
  @@index([createdById])
  @@index([updatedById])
}

model SeatingTable {
  id            String     @id @default(uuid())
  arrangementId String
  name          String
  shape         TableShape @default(CIRCULAR)
  capacity      Int        @default(8)
  category      String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @default(now()) @updatedAt

  arrangement Arrangement      @relation(fields: [arrangementId], references: [id], onDelete: Cascade)
  assignments SeatAssignment[]

  @@index([arrangementId])
}

model SeatAssignment {
  id                 String  @id @default(uuid())
  tableId            String
  seatIndex          Int
  guestId            String?
  arrangementGuestId String?

  table            SeatingTable      @relation(fields: [tableId], references: [id], onDelete: Cascade)
  guest            Guest?            @relation(fields: [guestId], references: [id], onDelete: Cascade)
  arrangementGuest ArrangementGuest? @relation(fields: [arrangementGuestId], references: [id], onDelete: Cascade)

  @@unique([tableId, seatIndex])
  @@index([tableId])
  @@index([guestId])
  @@index([arrangementGuestId])
}

model ArrangementGuest {
  id            String   @id @default(uuid())
  arrangementId String
  name          String
  createdAt     DateTime @default(now())

  arrangement     Arrangement      @relation(fields: [arrangementId], references: [id], onDelete: Cascade)
  assignments     SeatAssignment[]
  roomAssignments RoomAssignment[]

  @@index([arrangementId])
}

model HotelRoom {
  id            String   @id @default(uuid())
  arrangementId String
  roomNumber    String
  familyName    String?
  capacity      Int      @default(2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  arrangement Arrangement      @relation(fields: [arrangementId], references: [id], onDelete: Cascade)
  assignments RoomAssignment[]

  @@index([arrangementId])
}

model RoomAssignment {
  id                 String  @id @default(uuid())
  roomId             String
  guestId            String? // Optional property allows arrangement companions allocation
  arrangementGuestId String? // Captures isolated local View companion rows securely

  room             HotelRoom         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  guest            Guest?            @relation(fields: [guestId], references: [id], onDelete: Cascade)
  arrangementGuest ArrangementGuest? @relation(fields: [arrangementGuestId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([guestId])
  @@index([arrangementGuestId])
}

model Vendor {
  id          String         @id @default(uuid())
  name        String
  category    VendorCategory
  description String?

  address   String
  city      String
  state     String
  country   String
  pincode   String?
  latitude  Float?
  longitude Float?

  phone    String
  email    String?
  whatsapp String?
  website  String?

  images String[]
  videos String[]

  startingPrice Int?
  pricingUnit   PricingUnit?

  avgRating      Float? @default(0)
  totalReviews   Int?   @default(0)
  externalRating Float?

  isActive Boolean  @default(true)
  services String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venueDetails   VenueDetails?
  makeupDetails  MakeupArtistDetails?
  photoDetails   PhotographerDetails?
  catererDetails CatererDetails?
  decorDetails   DecoratorDetails?
  plannerDetails PlannerDetails?
  mehndiDetails  MehndiArtistDetails?

  shortlists ShortlistedVendor[]
  reviews    VendorReview[]

  @@index([city])
  @@index([category])
  @@index([startingPrice])
  @@index([avgRating])
}

model VenueDetails {
  id       String @id @default(uuid())
  vendorId String @unique
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  venueType    VenueType
  hallCapacity Int?
  lawnCapacity Int?

  roomsAvailable Int?
  bridalSuite    Boolean @default(false)
  groomRoom      Boolean @default(false)

  amenities        String[]
  parkingAvailable Boolean  @default(false)
  parkingCapacity  Int?

  cateringPolicy   PolicyType
  alcoholPolicy    PolicyType
  decorationPolicy PolicyType

  starRating      Int?
  peakSeasonPrice Int?
  offSeasonPrice  Int?
}

model MakeupArtistDetails {
  id       String @id @default(uuid())
  vendorId String @unique
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  servicesOffered String[]
  experienceYears Int
  travels         Boolean  @default(false)
  travelCost      Int?

  bridalPrice    Int?
  partyPrice     Int?
  brandsUsed     String[]
  trialAvailable Boolean  @default(false)
}

model PhotographerDetails {
  id       String @id @default(uuid())
  vendorId String @unique
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  services        String[]
  experienceYears Int
  deliveryDays    Int
  teamSize        Int?
  equipment       String[]

  pricePerDay      Int?
  fullPackagePrice Int?
  albumIncluded    Boolean @default(false)
}

model CatererDetails {
  id       String @id @default(uuid())
  vendorId String @unique
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  cuisines            String[]
  vegOnly             Boolean  @default(false)
  vegPricePerPlate    Int?
  nonVegPricePerPlate Int?
  minGuestCount       Int?
  services            String[]
}

model DecoratorDetails {
  id       String @id @default(uuid())
  vendorId String @unique
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  decorationTypes String[]
  experienceYears Int
  basicPrice      Int?
  premiumPrice    Int?
  materialsUsed   String[]
  customizable    Boolean  @default(true)
}

model PlannerDetails {
  id       String @id @default(uuid())
  vendorId String @unique
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  services        String[]
  experienceYears Int
  eventsManaged   Int
  teamSize        Int?
  pricingModel    PricingModel
}

model MehndiArtistDetails {
  id       String @id @default(uuid())
  vendorId String @unique
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  styles          String[]
  experienceYears Int
  bridalPrice     Int?
  pricePerHand    Int?
  travels         Boolean  @default(false)
}

model ShortlistedVendor {
  id String @id @default(uuid())

  weddingId  String
  eventId    String?
  visibility Visibility @default(SHARED)

  vendorId    String
  createdById String
  notes       String?
  createdAt   DateTime @default(now())

  wedding   Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  event     Event?  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vendor    Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  createdBy User    @relation("ShortlistCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([weddingId, eventId, vendorId, visibility])
  @@index([weddingId])
  @@index([eventId])
  @@index([vendorId])
  @@index([weddingId, visibility, eventId])
}

model VendorReview {
  id        String   @id @default(uuid())
  vendorId  String
  userId    String
  rating    Float
  comment   String?
  createdAt DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([userId])
}
